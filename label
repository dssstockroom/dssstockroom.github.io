<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stockroom Label Generator</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jsbarcode/3.11.6/JsBarcode.all.min.js"></script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@300;400;500;600&family=Roboto:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg:      #0f1117;
    --surface: #181c26;
    --card:    #1e2334;
    --border:  #2a3047;
    --accent:  #3b82f6;
    --accent2: #22d3ee;
    --danger:  #f87171;
    --text:    #e2e8f0;
    --muted:   #64748b;
    --mono:    'IBM Plex Mono', monospace;
    --sans:    'IBM Plex Sans', sans-serif;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: var(--sans);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  header {
    border-bottom: 1px solid var(--border);
    padding: 16px 28px;
    display: flex; align-items: center; gap: 12px;
    background: var(--surface);
    flex-shrink: 0;
  }
  .logo-mark {
    width: 34px; height: 34px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 17px; flex-shrink: 0;
  }
  header h1 { font-size: 15px; font-weight: 600; }
  header .sub { font-size: 11px; color: var(--muted); font-family: var(--mono); }

  .app {
    display: grid;
    grid-template-columns: 300px 1fr;
    flex: 1; min-height: 0; overflow: hidden;
  }

  aside {
    background: var(--surface);
    border-right: 1px solid var(--border);
    overflow-y: auto;
    display: flex; flex-direction: column;
  }
  .s-section {
    padding: 18px;
    border-bottom: 1px solid var(--border);
  }
  .s-section h2 {
    font-size: 9.5px; font-weight: 700;
    letter-spacing: 0.13em; text-transform: uppercase;
    color: var(--muted); margin-bottom: 13px;
  }

  .drop-zone {
    position: relative;
    border: 1.5px dashed var(--border);
    border-radius: 9px; padding: 24px 14px;
    text-align: center; cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }
  .drop-zone:hover, .drop-zone.over {
    border-color: var(--accent);
    background: rgba(59,130,246,0.06);
  }
  .drop-zone input {
    position: absolute; inset: 0; opacity: 0;
    cursor: pointer; width: 100%; height: 100%;
  }
  .drop-icon { font-size: 26px; margin-bottom: 7px; }
  .drop-zone p { font-size: 12px; color: var(--muted); line-height: 1.5; }
  .drop-zone strong { color: var(--text); }
  .drop-hint { margin-top: 6px; font-size: 10px; font-family: var(--mono); color: var(--muted); }

  .file-pill {
    display: none; margin-top: 10px;
    background: var(--card); border-radius: 7px;
    padding: 9px 11px; align-items: center; gap: 8px; font-size: 11.5px;
  }
  .file-pill.show { display: flex; }
  .file-pill .fp-name { font-family: var(--mono); color: var(--accent2); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .file-pill .fp-ct  { color: var(--muted); white-space: nowrap; }

  .err-box {
    display: none; margin-top: 9px;
    background: rgba(248,113,113,0.1);
    border: 1px solid rgba(248,113,113,0.3);
    border-radius: 7px; padding: 9px 11px;
    font-size: 11.5px; color: var(--danger); line-height: 1.5;
  }
  .err-box.show { display: block; }

  .col-map {
    background: var(--card); border-radius: 8px;
    padding: 10px 12px; font-size: 10.5px;
    font-family: var(--mono); line-height: 2; color: var(--muted);
  }
  .col-map span { color: var(--accent2); font-weight: 600; }

  .ctrl { margin-bottom: 13px; }
  .ctrl label { display: block; font-size: 10.5px; font-family: var(--mono); color: var(--muted); margin-bottom: 5px; }
  .ctrl input, .ctrl select {
    width: 100%; background: var(--card);
    border: 1px solid var(--border); border-radius: 6px;
    color: var(--text); font-family: var(--mono); font-size: 12px;
    padding: 7px 9px; outline: none; transition: border-color 0.15s;
  }
  .ctrl input:focus, .ctrl select:focus { border-color: var(--accent); }
  .ctrl-hint { font-size: 9.5px; color: var(--muted); margin-top: 3px; }

  .btn {
    display: flex; align-items: center; justify-content: center; gap: 6px;
    width: 100%; padding: 9px 14px; border: none; border-radius: 7px;
    font-family: var(--sans); font-size: 13px; font-weight: 600;
    cursor: pointer; transition: all 0.15s;
  }
  .btn + .btn { margin-top: 7px; }
  .btn-primary { background: var(--accent); color: #fff; }
  .btn-primary:hover:not(:disabled) { background: #2563eb; }
  .btn-primary:disabled { background: #1e2740; color: var(--muted); cursor: not-allowed; }
  .btn-ghost { background: var(--card); color: var(--text); border: 1px solid var(--border); }
  .btn-ghost:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
  .btn-ghost:disabled { opacity: 0.4; cursor: not-allowed; }

  .spinner {
    width: 15px; height: 15px;
    border: 2px solid rgba(255,255,255,0.2);
    border-top-color: #fff; border-radius: 50%;
    animation: spin 0.7s linear infinite; display: none;
  }
  @keyframes spin { to { transform: rotate(360deg); } }

  /* ── Preview area ── */
  .preview-area {
    overflow: auto; padding: 28px;
    background: #0a0d14;
    display: flex; flex-direction: column; align-items: center;
  }
  .pg-header {
    width: 100%; max-width: 820px;
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 16px;
  }
  .pg-header h3 { font-size: 12px; color: var(--muted); font-weight: 400; }
  .pg-badge {
    font-size: 10.5px; font-family: var(--mono);
    background: var(--card); border: 1px solid var(--border);
    color: var(--muted); padding: 3px 9px; border-radius: 20px;
  }

  .sheet {
    background: white;
    width: 816px; height: 1056px;
    position: relative; flex-shrink: 0;
    box-shadow: 0 10px 50px rgba(0,0,0,0.7);
    margin-bottom: 28px;
  }

  /* ── Label cell (preview only) ── */
  .lc {
    position: absolute; overflow: hidden;
    background: #fff;
    /* Light border in preview for visual guidance — not in PDF */
    border: 0.5px solid #ccc;
    font-family: 'Roboto', Arial, sans-serif; color: #111;
  }
  .lc-inner {
    /* Generous edge padding — 8px sides, 6px top/bottom */
    padding: 6px 9px 5px 9px;
    height: 100%; display: flex; flex-direction: column;
  }

  /* Barcode stretches full inner width */
  .lc-bc {
    flex-shrink: 0;
    width: 100%;
    overflow: hidden;
  }
  .lc-bc svg {
    display: block;
    width: 100% !important;
    height: auto;
  }

  /* Item number — centered, bold, larger */
  .lc-num {
    text-align: center;
    font-size: 9px;
    font-weight: 700;
    color: #000;
    margin-top: 2px;
    flex-shrink: 0;
    letter-spacing: 0.04em;
  }

  /* Item name — centered, readable, wraps to 2 lines */
  .lc-name {
    text-align: center;
    font-size: 7.5px;
    font-weight: 400;
    color: #1a1a1a;
    line-height: 1.3;
    margin-top: 2px;
    flex-shrink: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .lc-div {
    border: none; border-top: 0.6px solid #bbb;
    margin: 3px 0 2px; flex-shrink: 0;
  }

  /* Bottom half: left col + right col */
  .lc-bottom {
    display: flex; flex: 1; gap: 6px;
    min-height: 0; align-items: flex-start;
  }
  .lc-left, .lc-right {
    display: flex; flex-direction: column;
    gap: 2px; overflow: hidden; flex: 1;
  }
  .lc-right { text-align: right; align-items: flex-end; }

  .lc-field {
    font-size: 7px;
    color: #333;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    max-width: 100%; line-height: 1.4;
  }
  .lc-field b { color: #000; }

  /* Location — bold, noticeably larger */
  .lc-loc {
    font-size: 8.5px;
    font-weight: 700;
    color: #000;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    max-width: 100%; line-height: 1.4;
  }

  .lc-empty { background: #f9f9f9; }

  .empty-state {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    min-height: 400px; width: 100%;
    color: var(--muted); text-align: center; gap: 10px;
  }
  .empty-state .ei { font-size: 44px; opacity: 0.25; }
  .empty-state p { font-size: 13px; max-width: 240px; line-height: 1.6; }
</style>
</head>
<body>

<header>
  <div class="logo-mark">🏷</div>
  <div>
    <h1>Stockroom Label Generator</h1>
    <span class="sub">Avery 5162 · 1⅓″ × 4″ · 14-up · Inventory Status Report</span>
  </div>
</header>

<div class="app">
  <aside>

    <div class="s-section">
      <h2>1 · Load Report</h2>
      <div class="drop-zone" id="dropZone">
        <input type="file" id="fileInput" accept=".xlsx,.xls,.csv">
        <div class="drop-icon">📊</div>
        <p><strong>Drop Inventory Status Report</strong><br>or click to browse</p>
        <div class="drop-hint">.xlsx &nbsp;·&nbsp; .xls &nbsp;·&nbsp; .csv</div>
      </div>
      <div class="file-pill" id="filePill">
        <span>✅</span>
        <span class="fp-name" id="fileName">—</span>
        <span class="fp-ct" id="itemCount">—</span>
      </div>
      <div class="err-box" id="errBox"></div>
    </div>

    <div class="s-section">
      <h2>Column Mapping</h2>
      <div class="col-map">
        <span>C</span> → Location<br>
        <span>E</span> → Item Number<br>
        <span>F</span> → Manufacturer #<br>
        <span>N</span> → Item Name<br>
        <span>O</span> → Unit of Measure<br>
        <span>P</span> → Alt Unit<br>
        <span>Q</span> → Conv. Factor
      </div>
      <div style="margin-top:9px;font-size:10px;color:var(--muted);line-height:1.6">
        Row 1 is always skipped as a header. Data begins at row 2.
      </div>
    </div>

    <div class="s-section">
      <h2>2 · Options</h2>
      <div class="ctrl">
        <label>Skip label positions (partial sheet)</label>
        <input type="number" id="startOffset" min="0" max="13" value="0">
        <div class="ctrl-hint">0 = top-left · 13 = last position on first sheet</div>
      </div>
      <div class="ctrl">
        <label>Barcode format</label>
        <select id="barcodeType">
          <option value="CODE128">Code 128 (recommended)</option>
          <option value="CODE39">Code 39</option>
        </select>
      </div>
    </div>

    <div class="s-section">
      <h2>3 · Output</h2>
      <button class="btn btn-primary" id="pdfBtn" disabled>
        <span id="pdfSpinner" class="spinner"></span>
        <span id="pdfLabel">⬇ Download PDF</span>
      </button>
      <button class="btn btn-ghost" id="previewBtn" disabled>
        👁 Refresh Preview
      </button>
    </div>

  </aside>

  <main class="preview-area" id="previewArea">
    <div class="empty-state" id="emptyState">
      <div class="ei">🏷</div>
      <p>Load an Inventory Status Report to preview labels before printing.</p>
    </div>
  </main>
</div>

<script>
// ══════════════════════════════════════════════════════════════════════════
// Layout constants
// ══════════════════════════════════════════════════════════════════════════

// Preview pixel dimensions at 96 dpi
const PX = {
  PAGE_W:816, PAGE_H:1056,
  LABEL_W:384, LABEL_H:128,
  COLS:2, ROWS:7,
  MARGIN_L:15, MARGIN_T:48, COL_GAP:18,
  // Inner padding (px) — kept generous
  PAD_X:9, PAD_Y:6
};

// PDF point dimensions at 72 pt/in
const PT = {
  PAGE_W:612, PAGE_H:792,
  LABEL_W:288, LABEL_H:96,      // 4" × 1.333"
  COLS:2, ROWS:7,
  MARGIN_L:11.25, MARGIN_T:36,  // 0.15625" × 72,  0.5" × 72
  COL_GAP:13.5,                 // 0.1875" × 72
  // Inner padding (pt) — generous to prevent bleed
  PAD_X:7, PAD_Y:5
};

// Column indices (0-based): C=2, E=4, F=5, N=13, O=14, P=15, Q=16
const COL = { loc:2, itemNum:4, mfrNum:5, name:13, uom:14, altUnit:15, convFactor:16 };

// ══════════════════════════════════════════════════════════════════════════
// File loading — always skip row index 0 (row 1, the header)
// ══════════════════════════════════════════════════════════════════════════
let data = [];

function handleFile(file) {
  clearError();
  const ext = file.name.split('.').pop().toLowerCase();

  if (ext === 'csv') {
    const reader = new FileReader();
    reader.onload = e => {
      const lines = e.target.result.split(/\r?\n/);
      const rows  = lines.map(l => l.split(',').map(c => c.replace(/^"|"$/g,'').trim()));
      ingestRows(rows, file.name);
    };
    reader.readAsText(file);
  } else if (['xlsx','xls'].includes(ext)) {
    const reader = new FileReader();
    reader.onload = e => {
      try {
        const wb   = XLSX.read(e.target.result, { type:'array', raw:false });
        const ws   = wb.Sheets[wb.SheetNames[0]];
        const rows = XLSX.utils.sheet_to_json(ws, { header:1, defval:'' });
        ingestRows(rows, file.name);
      } catch(err) { showError('Could not read file: ' + err.message); }
    };
    reader.readAsArrayBuffer(file);
  } else {
    showError('Please use a .xlsx, .xls, or .csv file.');
  }
}

function ingestRows(allRows, fname) {
  // Always skip row 0 (the header row), start from index 1
  const items = [];
  for (let i = 1; i < allRows.length; i++) {
    const row = allRows[i];
    const val = String(row[COL.itemNum] ?? '').trim();
    if (!val) continue; // skip empty rows
    items.push({
      itemNum:    String(row[COL.itemNum]    ?? '').trim(),
      name:       String(row[COL.name]       ?? '').trim(),
      mfrNum:     String(row[COL.mfrNum]     ?? '').trim(),
      loc:        String(row[COL.loc]        ?? '').trim(),
      uom:        String(row[COL.uom]        ?? '').trim(),
      altUnit:    String(row[COL.altUnit]    ?? '').trim(),
      convFactor: String(row[COL.convFactor] ?? '').trim(),
    });
  }

  if (!items.length) {
    showError('No data rows found after row 1. Make sure column E contains item numbers starting in row 2.');
    return;
  }

  data = items;
  document.getElementById('fileName').textContent  = fname;
  document.getElementById('itemCount').textContent = `${items.length} item${items.length===1?'':'s'}`;
  document.getElementById('filePill').classList.add('show');
  document.getElementById('pdfBtn').disabled    = false;
  document.getElementById('previewBtn').disabled = false;
  renderPreview();
}

// ══════════════════════════════════════════════════════════════════════════
// Drag & drop / file input
// ══════════════════════════════════════════════════════════════════════════
const dz = document.getElementById('dropZone');
dz.addEventListener('dragover',  e => { e.preventDefault(); dz.classList.add('over'); });
dz.addEventListener('dragleave', () => dz.classList.remove('over'));
dz.addEventListener('drop',      e => { e.preventDefault(); dz.classList.remove('over'); if (e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]); });
document.getElementById('fileInput').addEventListener('change', e => { if (e.target.files[0]) handleFile(e.target.files[0]); });

// ══════════════════════════════════════════════════════════════════════════
// Helpers
// ══════════════════════════════════════════════════════════════════════════
function showError(msg) {
  const b = document.getElementById('errBox');
  b.textContent = msg; b.classList.add('show');
  document.getElementById('filePill').classList.remove('show');
  data = [];
  document.getElementById('pdfBtn').disabled    = true;
  document.getElementById('previewBtn').disabled = true;
}
function clearError() {
  const b = document.getElementById('errBox');
  b.textContent = ''; b.classList.remove('show');
}
function altDisplay(item) {
  return [item.convFactor, item.altUnit].filter(s => s && s !== '0').join(' ');
}
function esc(str) {
  return String(str??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function clampOffset() {
  const v = parseInt(document.getElementById('startOffset').value)||0;
  return Math.max(0, Math.min(13, v));
}

// ══════════════════════════════════════════════════════════════════════════
// Preview rendering
// ══════════════════════════════════════════════════════════════════════════
function labelOriginPx(idx) {
  return {
    x: PX.MARGIN_L + (idx % PX.COLS) * (PX.LABEL_W + PX.COL_GAP),
    y: PX.MARGIN_T + Math.floor(idx / PX.COLS) * PX.LABEL_H
  };
}

function makeLabelElement(item, barcodeType) {
  const cell  = document.createElement('div');
  cell.className = 'lc';

  const inner = document.createElement('div');
  inner.className = 'lc-inner';

  // ── Barcode (full inner width) ─────────────────────────────────────────
  const bcWrap = document.createElement('div');
  bcWrap.className = 'lc-bc';
  try {
    const svg = document.createElementNS('http://www.w3.org/2000/svg','svg');
    JsBarcode(svg, item.itemNum || '00000', {
      format: barcodeType, width: 1.4, height: 30,
      displayValue: false, margin: 0,
      background: '#ffffff', lineColor: '#000000'
    });
    // Force SVG to stretch to 100% width; height scales with aspect ratio
    svg.removeAttribute('width');
    svg.removeAttribute('height');
    svg.setAttribute('preserveAspectRatio','none');
    svg.style.width  = '100%';
    svg.style.height = '32px';
    bcWrap.appendChild(svg);
  } catch(e) { bcWrap.textContent = item.itemNum; }
  inner.appendChild(bcWrap);

  // ── Item number ────────────────────────────────────────────────────────
  const num = document.createElement('div');
  num.className   = 'lc-num';
  num.textContent = item.itemNum;
  inner.appendChild(num);

  // ── Item name ──────────────────────────────────────────────────────────
  const name = document.createElement('div');
  name.className   = 'lc-name';
  name.textContent = item.name;
  inner.appendChild(name);

  // ── Divider ────────────────────────────────────────────────────────────
  const hr = document.createElement('hr');
  hr.className = 'lc-div';
  inner.appendChild(hr);

  // ── Bottom two-column block ────────────────────────────────────────────
  const bottom = document.createElement('div');
  bottom.className = 'lc-bottom';

  // Left: Mfr# then UOM
  const left = document.createElement('div');
  left.className = 'lc-left';
  const mfr = document.createElement('div');
  mfr.className = 'lc-field';
  mfr.innerHTML = `<b>Mfr#</b> ${esc(item.mfrNum)}`;
  left.appendChild(mfr);
  const uom = document.createElement('div');
  uom.className = 'lc-field';
  uom.innerHTML = `<b>UOM</b> ${esc(item.uom)}`;
  left.appendChild(uom);

  // Right: Location (bold/large) then Alt UOM
  const right = document.createElement('div');
  right.className = 'lc-right';
  const loc = document.createElement('div');
  loc.className   = 'lc-loc';
  loc.textContent = item.loc;
  right.appendChild(loc);
  const alt = altDisplay(item);
  if (alt) {
    const altEl = document.createElement('div');
    altEl.className   = 'lc-field';
    altEl.textContent = alt;
    right.appendChild(altEl);
  }

  bottom.appendChild(left);
  bottom.appendChild(right);
  inner.appendChild(bottom);
  cell.appendChild(inner);
  return cell;
}

function renderPreview() {
  const area = document.getElementById('previewArea');
  document.getElementById('emptyState').style.display = 'none';
  area.querySelectorAll('.pg-header,.sheet').forEach(el => el.remove());

  const offset      = clampOffset();
  const barcodeType = document.getElementById('barcodeType').value;
  const numPages    = Math.ceil((offset + data.length) / (PX.COLS * PX.ROWS));

  for (let p = 0; p < numPages; p++) {
    const hdr = document.createElement('div');
    hdr.className = 'pg-header';
    hdr.innerHTML = `<h3>Page ${p+1} of ${numPages}</h3><span class="pg-badge">2 × 7 · 14 labels/sheet</span>`;
    area.appendChild(hdr);

    const sheet = document.createElement('div');
    sheet.className = 'sheet';

    for (let slot = 0; slot < PX.COLS * PX.ROWS; slot++) {
      const globalSlot = p * PX.COLS * PX.ROWS + slot;
      const itemIdx    = globalSlot - offset;
      const { x, y }  = labelOriginPx(slot);

      if (itemIdx >= 0 && itemIdx < data.length) {
        const el = makeLabelElement(data[itemIdx], barcodeType);
        el.style.cssText = `left:${x}px;top:${y}px;width:${PX.LABEL_W}px;height:${PX.LABEL_H}px;`;
        sheet.appendChild(el);
      } else {
        const empty = document.createElement('div');
        empty.className  = 'lc lc-empty';
        empty.style.cssText = `left:${x}px;top:${y}px;width:${PX.LABEL_W}px;height:${PX.LABEL_H}px;`;
        sheet.appendChild(empty);
      }
    }
    area.appendChild(sheet);
  }
}

// ══════════════════════════════════════════════════════════════════════════
// PDF generation
// No border drawn — no rect() call.
// Barcode canvas is rendered at high resolution then drawn at full inner width.
// ══════════════════════════════════════════════════════════════════════════
function labelOriginPt(idx) {
  return {
    x: PT.MARGIN_L + (idx % PT.COLS) * (PT.LABEL_W + PT.COL_GAP),
    y: PT.PAGE_H - PT.MARGIN_T - (Math.floor(idx / PT.COLS) + 1) * PT.LABEL_H
  };
}

async function generatePDF() {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ unit:'pt', format:'letter', orientation:'portrait' });

  const offset      = clampOffset();
  const barcodeType = document.getElementById('barcodeType').value;
  let pos           = offset;

  const INNER_W = PT.LABEL_W - 2 * PT.PAD_X;

  // Truncate text to fit maxW at current font settings
  function fit(text, maxW) {
    let t = String(text ?? '');
    if (doc.getTextWidth(t) <= maxW) return t;
    while (t.length > 1 && doc.getTextWidth(t+'…') > maxW) t = t.slice(0,-1);
    return t + '…';
  }

  // Word-wrap text to max 2 lines
  function wrap2(text, maxW) {
    const words = String(text ?? '').split(' ');
    const lines = []; let cur = '';
    for (const w of words) {
      const test = cur ? cur+' '+w : w;
      if (doc.getTextWidth(test) > maxW) {
        if (cur) lines.push(cur);
        cur = w;
        if (lines.length >= 1) break;
      } else { cur = test; }
    }
    if (cur) lines.push(cur);
    return lines.slice(0,2);
  }

  for (let i = 0; i < data.length; i++) {
    if (pos >= PT.COLS * PT.ROWS) { doc.addPage(); pos = 0; }

    const item     = data[i];
    const { x, y } = labelOriginPt(pos);
    const PAD      = PT.PAD_X;
    const PADY     = PT.PAD_Y;

    // ── NO BORDER — rect() intentionally omitted ───────────────────────

    // ── Barcode: render to canvas at 3× resolution, draw at full inner width ──
    // BC_H: height of the barcode image in the PDF (pt)
    const BC_H  = 22;
    // Place barcode at the top of the label interior
    const BC_TOP = y + PT.LABEL_H - PADY - BC_H;

    try {
      const bcCanvas = document.createElement('canvas');
      // Render at high resolution for crisp output; JsBarcode sets canvas size
      JsBarcode(bcCanvas, item.itemNum || '00000', {
        format: barcodeType,
        // width = px per bar; height = canvas height in px
        // We scale horizontally ourselves after the fact
        width: 2, height: 80,
        displayValue: false,
        margin: 0,
        background: '#ffffff',
        lineColor: '#000000'
      });
      // Draw image stretched to full inner width, no border-to-border bleed
      doc.addImage(
        bcCanvas.toDataURL('image/png'), 'PNG',
        x + PAD,          // x: left edge + padding
        BC_TOP,           // y: top of barcode zone
        INNER_W,          // width: full inner width → barcode stretches edge-to-edge
        BC_H              // height: fixed pt height
      );
    } catch(e) { /* skip barcode on error */ }

    // ── Item number — centered, bold, 10pt ────────────────────────────
    const NUM_Y = BC_TOP + BC_H + 7;
    doc.setFont('helvetica', 'bold');
    doc.setFontSize(10);
    doc.setTextColor(0, 0, 0);
    doc.text(item.itemNum || '', x + PT.LABEL_W / 2, NUM_Y, { align:'center' });

    // ── Item name — centered, normal, 8.5pt, up to 2 lines ───────────
    doc.setFont('helvetica', 'normal');
    doc.setFontSize(8.5);
    doc.setTextColor(20, 20, 20);
    const nameLines = wrap2(item.name, INNER_W);
    let nameY = NUM_Y + 9;
    for (const line of nameLines) {
      doc.text(line, x + PT.LABEL_W / 2, nameY, { align:'center' });
      nameY += 9.5;
    }

    // ── Divider ────────────────────────────────────────────────────────
    const DIV_Y = nameY + 1;
    doc.setDrawColor(170, 170, 170);
    doc.setLineWidth(0.35);
    doc.line(x + PAD, DIV_Y, x + PT.LABEL_W - PAD, DIV_Y);

    // ── Bottom block ───────────────────────────────────────────────────
    // Left column starts at left edge, right column right-aligns to right edge
    // Both columns are given half the inner width minus a small gutter
    const COL_W   = INNER_W / 2 - 3;
    const LEFT_X  = x + PAD;
    const RIGHT_X = x + PT.LABEL_W - PAD;
    let   LEFT_Y  = DIV_Y + 8;
    let   RIGHT_Y = DIV_Y + 8;

    // Left: Mfr#
    doc.setFontSize(7);
    doc.setFont('helvetica', 'bold');
    doc.setTextColor(0, 0, 0);
    const MFR_LBL = 'Mfr# ';
    const mfrLW   = doc.getTextWidth(MFR_LBL);
    doc.text(MFR_LBL, LEFT_X, LEFT_Y);
    doc.setFont('helvetica', 'normal');
    doc.setTextColor(40, 40, 40);
    doc.text(fit(item.mfrNum, COL_W - mfrLW), LEFT_X + mfrLW, LEFT_Y);
    LEFT_Y += 8;

    // Left: UOM
    doc.setFontSize(7);
    doc.setFont('helvetica', 'bold');
    doc.setTextColor(0, 0, 0);
    const UOM_LBL = 'UOM ';
    const uomLW   = doc.getTextWidth(UOM_LBL);
    doc.text(UOM_LBL, LEFT_X, LEFT_Y);
    doc.setFont('helvetica', 'normal');
    doc.setTextColor(40, 40, 40);
    doc.text(fit(item.uom, COL_W - uomLW), LEFT_X + uomLW, LEFT_Y);

    // Right: Location — bold, 9pt
    doc.setFontSize(9);
    doc.setFont('helvetica', 'bold');
    doc.setTextColor(0, 0, 0);
    doc.text(fit(item.loc, COL_W), RIGHT_X, RIGHT_Y, { align:'right' });
    RIGHT_Y += 9;

    // Right: Alt UOM / conversion factor
    const altStr = altDisplay(item);
    if (altStr) {
      doc.setFontSize(7);
      doc.setFont('helvetica', 'normal');
      doc.setTextColor(60, 60, 60);
      doc.text(fit(altStr, COL_W), RIGHT_X, RIGHT_Y, { align:'right' });
    }

    pos++;
  }

  doc.save('shelf_labels.pdf');
}

// ══════════════════════════════════════════════════════════════════════════
// Wire-up
// ══════════════════════════════════════════════════════════════════════════
document.getElementById('previewBtn').addEventListener('click', () => {
  if (data.length) renderPreview();
});

document.getElementById('pdfBtn').addEventListener('click', async () => {
  if (!data.length) return;
  const btn  = document.getElementById('pdfBtn');
  const lbl  = document.getElementById('pdfLabel');
  const spin = document.getElementById('pdfSpinner');
  btn.disabled = true; lbl.textContent = 'Generating…'; spin.style.display = 'inline-block';
  await new Promise(r => setTimeout(r, 30));
  try { await generatePDF(); }
  catch(e) { showError('PDF error: ' + e.message); }
  btn.disabled = false; lbl.textContent = '⬇ Download PDF'; spin.style.display = 'none';
});

document.getElementById('startOffset').addEventListener('change', () => { if (data.length) renderPreview(); });
document.getElementById('barcodeType').addEventListener('change', () => { if (data.length) renderPreview(); });
</script>
</body>
</html>
